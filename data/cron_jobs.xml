<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Auto-generate payslips for current month -->
    <record id="ir_cron_auto_generate_payslips" model="ir.cron">
        <field name="name">Auto-Generate Payslips</field>
        <field name="model_id" ref="model_hr_payroll_period"/>
        <field name="state">code</field>
        <field name="code">model.action_auto_generate_payslips()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active" eval="False"/>
    </record>

    <!-- Cron to update loan installment status -->
    <record id="ir_cron_update_loan_status" model="ir.cron">
        <field name="name">Update Loan Installment Status</field>
        <field name="model_id" ref="model_hr_employee_loan_installment"/>
        <field name="state">code</field>
        <field name="code">
# Update overdue installments
today = fields.Date.today()
overdue = model.search([('due_date', '&lt;', today), ('state', '=', 'pending')])
for record in overdue:
    record.write({'state': 'overdue'})
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="False"/>
    </record>
</odoo>
