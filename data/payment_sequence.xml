<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Salary Payment Run Sequence -->
        <!-- Format: PAY-RUN-YYYY-0001 -->
        <record id="seq_hr_payroll_payment_run" model="ir.sequence">
            <field name="name">Salary Payment Run</field>
            <field name="code">hr.payroll.payment.run</field>
            <field name="prefix">PAY-RUN-%(year)s-</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">4</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Vendor Invoice Sequence -->
        <!-- Format: VIN-0001 -->
        <record id="seq_account_invoice_incoming" model="ir.sequence">
            <field name="name">Vendor Invoice Incoming</field>
            <field name="code">account.invoice.incoming</field>
            <field name="prefix">VIN-</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">4</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Vendor Payment Run Sequence -->
        <!-- Format: VPAY-0001 -->
        <record id="seq_account_payment_run" model="ir.sequence">
            <field name="name">Vendor Payment Run</field>
            <field name="code">account.payment.run</field>
            <field name="prefix">VPAY-</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">4</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Work Order (SPK) Sequence -->
        <!-- Format: SPK-MM-YYYY-0001 -->
        <record id="seq_hr_work_order_spk" model="ir.sequence">
            <field name="name">Work Order SPK</field>
            <field name="code">hr.work.order.spk</field>
            <field name="prefix">SPK-%(month)02d-%(year)s-</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">4</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Customer Invoice Sequence -->
        <!-- Format: INV-0001 -->
        <record id="seq_sale_invoice_customer" model="ir.sequence">
            <field name="name">Customer Invoice</field>
            <field name="code">sale.invoice.customer</field>
            <field name="prefix">INV-</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">4</field>
            <field name="implementation">standard</field>
        </record>

    </data>
</odoo>
