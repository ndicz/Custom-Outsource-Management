<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_generate_client_profitability_wizard_form" model="ir.ui.view">
        <field name="name">generate.client.profitability.wizard.form</field>
        <field name="model">generate.client.profitability.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Laporan Profitabilitas Client">
                <group>
                    <field name="partner_id" domain="[('customer_rank', '&gt;', 0)]"/>
                    <field name="project_id" domain="[('partner_id', '=', partner_id)]"/>
                    <field name="period_start"/>
                    <field name="period_end"/>
                </group>
                <footer>
                    <button name="action_generate_profitability" type="object" string="Generate Laporan" class="btn-primary"/>
                    <button string="Batal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_generate_client_profitability_wizard" model="ir.actions.act_window">
        <field name="name">Generate Laporan Profitabilitas</field>
        <field name="res_model">generate.client.profitability.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_generate_client_profitability"
              name="Generate Laporan Profitabilitas"
              parent="menu_financial_reports"
              action="action_generate_client_profitability_wizard"
              sequence="25"/>
</odoo>
