<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_efaktur_export_wizard_form" model="ir.ui.view">
        <field name="name">outsource.efaktur.export.wizard.form</field>
        <field name="model">outsource.efaktur.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export e-Faktur ke DJP Online">
                <group invisible="state == 'done'">
                    <group string="Periode">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <group invisible="state != 'done'">
                    <field name="file_data" filename="filename" widget="binary"
                           string="File CSV siap download"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_export" type="object"
                            string="Generate CSV" class="btn-primary"
                            invisible="state == 'done'"/>
                    <button special="cancel" string="Tutup"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
