<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- HR Salary Component Views -->
    <record id="view_hr_salary_component_list" model="ir.ui.view">
        <field name="name">hr.salary.component.list</field>
        <field name="model">hr.salary.component</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="category"/>
                <field name="amount_type"/>
                <field name="sequence"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hr_salary_component_form" model="ir.ui.view">
        <field name="name">hr.salary.component.form</field>
        <field name="model">hr.salary.component</field>
        <field name="arch" type="xml">
            <form string="Komponen Gaji">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="category"/>
                    </group>
                    <group>
                        <field name="amount_type"/>
                        <field name="percentage_base" invisible="amount_type != 'percentage'"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group string="Perhitungan">
                        <field name="compute_method"/>
                        <field name="formula_code" invisible="compute_method != 'formula'" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_salary_component" model="ir.actions.act_window">
        <field name="name">Komponen Gaji</field>
        <field name="res_model">hr.salary.component</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- HR Salary Structure Views -->
    <record id="view_hr_salary_structure_list" model="ir.ui.view">
        <field name="name">hr.salary.structure.list</field>
        <field name="model">hr.salary.structure</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hr_salary_structure_form" model="ir.ui.view">
        <field name="name">hr.salary.structure.form</field>
        <field name="model">hr.salary.structure</field>
        <field name="arch" type="xml">
            <form string="Struktur Gaji">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="is_default"/>
                    </group>
                    <field name="salary_component_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="code"/>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="amount_type"/>
                            <field name="sequence"/>
                        </list>
                    </field>
                    <group string="Catatan">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_salary_structure" model="ir.actions.act_window">
        <field name="name">Struktur Gaji</field>
        <field name="res_model">hr.salary.structure</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- HR Payroll Period Views -->
    <record id="view_hr_payroll_period_list" model="ir.ui.view">
        <field name="name">hr.payroll.period.list</field>
        <field name="model">hr.payroll.period</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'closed'" decoration-warning="state == 'locked'">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="payslip_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hr_payroll_period_form" model="ir.ui.view">
        <field name="name">hr.payroll.period.form</field>
        <field name="model">hr.payroll.period</field>
        <field name="arch" type="xml">
            <form string="Periode Payroll">
                <header>
                    <button name="action_open" type="object" string="Buka Periode" 
                        invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_lock" type="object" string="Kunci Periode" 
                        invisible="state not in ('draft', 'open')" class="btn-warning"/>
                    <button name="action_close" type="object" string="Tutup Periode" 
                        invisible="state != 'locked'" class="btn-success"/>
                    <button name="action_auto_generate_payslips" type="object" string="Auto-Generate Slips" 
                        invisible="state != 'open'" class="btn-info"/>
                    <field name="state" widget="statusbar" nolabel="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group>
                            <field name="month" readonly="1"/>
                            <field name="year" readonly="1"/>
                            <field name="payslip_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_payroll_period" model="ir.actions.act_window">
        <field name="name">Periode Payroll</field>
        <field name="res_model">hr.payroll.period</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
