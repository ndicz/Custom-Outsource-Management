<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menu Outsource di top level -->
    <menuitem id="menu_outsource_root"
              name="Outsource"
              sequence="5"
              web_icon="outsource_custom,static/description/icon.png"/>
    <!-- ============================================================ -->
    <!--  Actions untuk sub-menu baru                                 -->
    <!-- ============================================================ -->
    <record id="action_outsource_clients" model="ir.actions.act_window">
        <field name="name">Klien</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('customer_rank', '&gt;', 0)]</field>
        <field name="context">{'default_customer_rank': 1}</field>
    </record>

    <record id="action_outsource_pipeline" model="ir.actions.act_window">
        <field name="name">Pipeline</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('type', '=', 'opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

    <record id="action_outsource_sale_orders" model="ir.actions.act_window">
        <field name="name">Kontrak / Sales Order</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_outsource_projects" model="ir.actions.act_window">
        <field name="name">Proyek</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Sub-menu: Bisnis -->
    <menuitem id="menu_outsource_bisnis"
              name="Bisnis"
              parent="menu_outsource_root"
              sequence="5"/>
    <menuitem id="menu_outsource_clients"
              name="Klien"
              parent="menu_outsource_bisnis"
              action="outsource_custom.action_outsource_clients"
              sequence="10"/>
    <menuitem id="menu_outsource_pipeline"
              name="Pipeline CRM"
              parent="menu_outsource_bisnis"
              action="outsource_custom.action_outsource_pipeline"
              sequence="20"/>
    <menuitem id="menu_outsource_sale_orders"
              name="Kontrak / Sales Order"
              parent="menu_outsource_bisnis"
              action="outsource_custom.action_outsource_sale_orders"
              sequence="30"/>
    <menuitem id="menu_outsource_projects"
              name="Proyek"
              parent="menu_outsource_bisnis"
              action="outsource_custom.action_outsource_projects"
              sequence="40"/>
    <!-- Sub-menu Pajak & Laporan -->
    <menuitem id="menu_outsource_tax"
              name="Pajak &amp; laporan"
              parent="menu_outsource_root"
              sequence="40"/>
    <menuitem id="menu_efaktur_export"
              name="Export e-Faktur"
              parent="menu_outsource_tax"
              action="outsource_custom.action_efaktur_wizard_accounting"
              sequence="10"/>
    <menuitem id="menu_bpjs_report"
              name="Laporan BPJS bulanan"
              parent="menu_outsource_tax"
              action="outsource_custom.action_bpjs_wizard"
              sequence="20"/>

    <!-- Sub-menu Setup Payroll -->
    <menuitem id="menu_outsource_setup"
              name="Setup Payroll"
              parent="menu_outsource_root"
              sequence="25"/>
    <menuitem id="menu_salary_component"
              name="Komponen Gaji"
              parent="menu_outsource_setup"
              action="outsource_custom.action_hr_salary_component"
              sequence="10"/>
    <menuitem id="menu_salary_structure"
              name="Struktur Gaji"
              parent="menu_outsource_setup"
              action="outsource_custom.action_hr_salary_structure"
              sequence="20"/>

    <menuitem id="menu_outsource_payroll"
              name="Payroll"
              parent="menu_outsource_root"
              sequence="30"/>
    <menuitem id="menu_outsource_payslip"
              name="Slip Gaji"
              parent="menu_outsource_payroll"
              action="outsource_custom.action_outsource_payslip"
              sequence="10"/>
    <menuitem id="menu_payroll_period"
              name="Periode Payroll"
              parent="menu_outsource_payroll"
              action="outsource_custom.action_hr_payroll_period"
              sequence="15"/>
    <menuitem id="menu_outsource_employee_salary"
              name="Gaji Karyawan"
              parent="menu_outsource_payroll"
              action="hr.open_view_employee_list"
              sequence="20"/>
    <menuitem id="menu_employee_loans"
              name="Pinjaman Karyawan"
              parent="menu_outsource_payroll"
              action="outsource_custom.action_hr_employee_loan"
              sequence="25"/>
    <menuitem id="menu_outsource_salary_summary"
              name="Summary Gaji Tahunan"
              parent="menu_outsource_payroll"
              action="outsource_custom.action_salary_summary_report"
              sequence="30"/>

    <record id="action_payslip_bank_export_menu" model="ir.actions.act_window">
        <field name="name">Export Payroll untuk Bank</field>
        <field name="res_model">payslip.bank.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_payslip_bank_export"
              name="Export Payroll"
              parent="menu_outsource_payroll"
              action="outsource_custom.action_payslip_bank_export_menu"
              sequence="40"/>
</odoo>
