<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_outsource" model="ir.ui.view">
        <field name="name">account.move.form.outsource</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="outsource_tax" string="Outsource"
                      invisible="move_type not in ['out_invoice', 'out_refund']">
                    <group string="Referensi">
                        <field name="contract_number"/>
                        <field name="po_number_client"/>
                        <field name="efaktur_number"/>
                    </group>
                    <group string="PPh 23">
                        <field name="pph23_withheld" widget="boolean_toggle"/>
                        <field name="pph23_rate"      invisible="not pph23_withheld"/>
                        <field name="pph23_amount"    invisible="not pph23_withheld"/>
                        <field name="amount_received" invisible="not pph23_withheld"
                               string="Diterima (net)"/>
                    </group>
                    <div invisible="efaktur_status != 'draft' or state != 'posted'">
                        <button name="action_generate_efaktur" type="object"
                                string="Generate e-Faktur" class="btn btn-primary"/>
                    </div>
                    <div invisible="efaktur_status != 'generated' or state != 'posted'">
                        <button name="action_upload_coretax" type="object"
                                string="Upload ke Coretax" class="btn btn-success"/>
                    </div>
                    <group string="Coretax" invisible="efaktur_status != 'generated'">
                        <field name="coretax_status" readonly="1"/>
                        <field name="coretax_uploaded_at" readonly="1"/>
                        <field name="coretax_response" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_efaktur_wizard_accounting" model="ir.actions.act_window">
        <field name="name">Export e-Faktur CSV</field>
        <field name="res_model">outsource.efaktur.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_bpjs_wizard" model="ir.actions.act_window">
        <field name="name">Laporan BPJS Bulanan</field>
        <field name="res_model">outsource.bpjs.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
