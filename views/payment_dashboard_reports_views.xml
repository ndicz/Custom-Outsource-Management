<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================ -->
        <!-- PAYMENT DASHBOARD WIDGET -->
        <!-- ================================================================ -->

        <!-- Dashboard Tree View -->
        <record id="payment_dashboard_tree" model="ir.ui.view">
            <field name="name">payment.dashboard.tree</field>
            <field name="model">payment.dashboard</field>
            <field name="arch" type="xml">
                <list string="Payment Dashboard" create="false" edit="false" delete="false">
                    <field name="salary_pending_count"/>
                    <field name="vendor_pending_count"/>
                    <field name="pending_proof_count"/>
                    <field name="overdue_count"/>
                    <field name="reconciled_today_count"/>
                </list>
            </field>
        </record>

        <!-- Dashboard Form View -->
        <record id="payment_dashboard_form" model="ir.ui.view">
            <field name="name">payment.dashboard.form</field>
            <field name="model">payment.dashboard</field>
            <field name="arch" type="xml">
                <form string="Payment Dashboard" create="false" edit="false" delete="false">
                    <sheet>
                        <div class="container-fluid">
                            <div class="row mt-3">
                                <div class="col-md-4 text-center">
                                    <div style="background-color: #FFC107; border-radius: 10px; padding: 20px;">
                                        <h3 style="margin: 0; color: white;">
                                            <field name="salary_pending_count" readonly="1"/>
                                        </h3>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 14px;">Salary Payments Ready</p>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 12px;">
                                            <field name="salary_pending_amount" readonly="1" widget="monetary"/>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-4 text-center">
                                    <div style="background-color: #17A2B8; border-radius: 10px; padding: 20px;">
                                        <h3 style="margin: 0; color: white;">
                                            <field name="vendor_pending_count" readonly="1"/>
                                        </h3>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 14px;">Vendor Invoices Pending</p>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 12px;">
                                            <field name="vendor_pending_amount" readonly="1" widget="monetary"/>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-4 text-center">
                                    <div style="background-color: #DC3545; border-radius: 10px; padding: 20px;">
                                        <h3 style="margin: 0; color: white;">
                                            <field name="overdue_count" readonly="1"/>
                                        </h3>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 14px;">âš ï¸ OVERDUE Payments</p>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 12px;">
                                            <field name="overdue_amount" readonly="1" widget="monetary"/>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-3">
                                <div class="col-md-4 text-center">
                                    <div style="background-color: #007BFF; border-radius: 10px; padding: 20px;">
                                        <h3 style="margin: 0; color: white;">
                                            <field name="pending_proof_count" readonly="1"/>
                                        </h3>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 14px;">Pending Proof Upload</p>
                                    </div>
                                </div>
                                <div class="col-md-4 text-center">
                                    <div style="background-color: #28A745; border-radius: 10px; padding: 20px;">
                                        <h3 style="margin: 0; color: white;">
                                            <field name="reconciled_today_count" readonly="1"/>
                                        </h3>
                                        <p style="margin: 5px 0 0 0; color: white; font-size: 14px;">Reconciled Today</p>
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-4">
                                <div class="col-md-12">
                                    <h4>Quick Actions</h4>
                                    <div style="display: flex; gap: 10px;">
                                        <button type="action" name="%(action_hr_payroll_payment_run)d" class="btn btn-sm btn-warning">
                                            Go to Salary Payments
                                        </button>
                                        <button type="action" name="%(action_account_invoice_incoming)d" class="btn btn-sm btn-info">
                                            Go to Vendor Invoices
                                        </button>
                                        <button type="action" name="%(outsource_custom.action_account_reconciliation)d" class="btn btn-sm btn-primary">
                                            View Reconciliation Report
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Dashboard Action -->
        <record id="action_payment_dashboard" model="ir.actions.act_window">
            <field name="name">Payment Dashboard</field>
            <field name="res_model">payment.dashboard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="payment_dashboard_form"/>
            <field name="context">{'form_view_ref': 'outsource_custom.payment_dashboard_form'}</field>
            <field name="help">Overview of all payment statuses and pending actions</field>
        </record>

        <!-- ================================================================ -->
        <!-- NOTIFICATION TEMPLATES -->
        <!-- ================================================================ -->

        <!-- Notification Template Tree View -->
        <record id="payment_notification_template_tree" model="ir.ui.view">
            <field name="name">payment.notification.template.tree</field>
            <field name="model">payment.notification.template</field>
            <field name="arch" type="xml">
                <list string="Notification Templates">
                    <field name="name"/>
                    <field name="notification_type"/>
                    <field name="auto_send"/>
                </list>
            </field>
        </record>

        <!-- Notification Template Form View -->
        <record id="payment_notification_template_form" model="ir.ui.view">
            <field name="name">payment.notification.template.form</field>
            <field name="model">payment.notification.template</field>
            <field name="arch" type="xml">
                <form string="Notification Template">
                    <sheet>
                        <group>
                            <field name="name" required="1"/>
                            <field name="notification_type" required="1"/>
                        </group>

                        <notebook>
                            <page string="Email Content" name="email_content">
                                <group>
                                    <field name="subject" required="1" colspan="2"/>
                                </group>
                                <field name="body_html" nolabel="1" colspan="2"/>
                            </page>

                            <page string="Settings" name="settings">
                                <group>
                                    <field name="auto_send"/>
                                    <field name="overdue_days" invisible="notification_type != 'payment_overdue'"/>
                                </group>
                                <field name="send_to_roles" nolabel="1" colspan="2"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Notification Template Action -->
        <record id="action_payment_notification_template" model="ir.actions.act_window">
            <field name="name">Notification Templates</field>
            <field name="res_model">payment.notification.template</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="payment_notification_template_tree"/>
            <field name="help">Configure payment notification email templates</field>
        </record>

        <!-- Notification Log Action -->
        <record id="action_payment_notification_log" model="ir.actions.act_window">
            <field name="name">Notification Logs</field>
            <field name="res_model">payment.notification.log</field>
            <field name="view_mode">list,form</field>
            <field name="help">View history of all sent payment notifications</field>
        </record>

        <!-- Notification Log Tree View -->
        <record id="payment_notification_log_tree" model="ir.ui.view">
            <field name="name">payment.notification.log.tree</field>
            <field name="model">payment.notification.log</field>
            <field name="arch" type="xml">
                <list string="Notification Logs" decoration-success="state == 'sent'" decoration-danger="state == 'failed'">
                    <field name="sent_date"/>
                    <field name="notification_type"/>
                    <field name="subject"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Notification Log Form View -->
        <record id="payment_notification_log_form" model="ir.ui.view">
            <field name="name">payment.notification.log.form</field>
            <field name="model">payment.notification.log</field>
            <field name="arch" type="xml">
                <form string="Notification Log">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,sent,failed"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="notification_type" readonly="1"/>
                                <field name="sent_by" readonly="1"/>
                            </group>
                            <group>
                                <field name="sent_date" readonly="1"/>
                                <field name="state" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <field name="subject" readonly="1" colspan="2"/>
                        </group>

                        <field name="body" nolabel="1" colspan="2" readonly="1"/>

                        <group invisible="state != 'failed'">
                            <field name="error_message" nolabel="1" colspan="2"/>
                        </group>

                        <div class="oe_chatter">
                            <field name="message_ids" widget="mail_thread"/>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================================================================ -->
        <!-- PAYMENT RECONCILIATION REPORT -->
        <!-- ================================================================ -->

        <!-- Reconciliation Report Tree View -->
        <record id="payment_reconciliation_report_tree" model="ir.ui.view">
            <field name="name">payment.reconciliation.report.tree</field>
            <field name="model">payment.reconciliation.report</field>
            <field name="arch" type="xml">
                <list string="Payment Reconciliation Report" create="false" edit="false" delete="false">
                    <field name="payment_date"/>
                    <field name="payment_type"/>
                    <field name="payment_ref"/>
                    <field name="amount"/>
                    <field name="gl_account"/>
                    <field name="debit_amount"/>
                    <field name="credit_amount"/>
                    <field name="gl_status"/>
                    <field name="variance"/>
                </list>
            </field>
        </record>

        <!-- Reconciliation Report Form View -->
        <record id="payment_reconciliation_report_form" model="ir.ui.view">
            <field name="name">payment.reconciliation.report.form</field>
            <field name="model">payment.reconciliation.report</field>
            <field name="arch" type="xml">
                <form string="Payment Reconciliation Report" create="false" edit="false" delete="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="payment_date" readonly="1"/>
                                <field name="payment_type" readonly="1"/>
                            </group>
                            <group>
                                <field name="payment_ref" readonly="1"/>
                                <field name="gl_status" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <group>
                                <field name="amount" readonly="1"/>
                                <field name="gl_account" readonly="1"/>
                            </group>
                            <group>
                                <field name="debit_amount" readonly="1"/>
                                <field name="credit_amount" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <group>
                                <field name="posted_date" readonly="1"/>
                                <field name="proof_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="variance" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Reconciliation Report Action -->
        <record id="action_payment_reconciliation_report" model="ir.actions.act_window">
            <field name="name">Payment Reconciliation Report</field>
            <field name="res_model">payment.reconciliation.report</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="payment_reconciliation_report_tree"/>
            <field name="help">Track all payment GL postings and reconciliation status</field>
        </record>

        <!-- ================================================================ -->
        <!-- PAYMENT AGING REPORT -->
        <!-- ================================================================ -->

        <!-- Aging Report Tree View -->
        <record id="payment_aging_report_tree" model="ir.ui.view">
            <field name="name">payment.aging.report.tree</field>
            <field name="model">payment.aging.report</field>
            <field name="arch" type="xml">
                <list string="Payment Aging Report" create="false" edit="false" delete="false"
                      decoration-danger="aging_bucket == '90plus' or aging_bucket == '61-90'"
                      decoration-warning="aging_bucket == '31-60' or aging_bucket == '1-30'">
                    <field name="invoice_ref"/>
                    <field name="vendor_name"/>
                    <field name="due_date"/>
                    <field name="days_overdue"/>
                    <field name="amount"/>
                    <field name="balance_due"/>
                    <field name="aging_bucket"/>
                    <field name="payment_status"/>
                </list>
            </field>
        </record>

        <!-- Aging Report Form View -->
        <record id="payment_aging_report_form" model="ir.ui.view">
            <field name="name">payment.aging.report.form</field>
            <field name="model">payment.aging.report</field>
            <field name="arch" type="xml">
                <form string="Payment Aging Report" create="false" edit="false" delete="false">
                    <sheet>
                        <div class="alert alert-warning" role="alert" invisible="days_overdue &lt;= 0">
                            <strong>âš ï¸ This invoice is <field name="days_overdue" readonly="1"/> days OVERDUE</strong>
                        </div>

                        <group>
                            <group>
                                <field name="invoice_ref" readonly="1"/>
                                <field name="vendor_name" readonly="1"/>
                                <field name="due_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="days_overdue" readonly="1"/>
                                <field name="aging_bucket" readonly="1"/>
                                <field name="payment_status" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <group>
                                <field name="amount" readonly="1"/>
                                <field name="paid_amount" readonly="1"/>
                            </group>
                            <group>
                                <field name="balance_due" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Aging Report Action -->
        <record id="action_payment_aging_report" model="ir.actions.act_window">
            <field name="name">Payment Aging Report</field>
            <field name="res_model">payment.aging.report</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="payment_aging_report_tree"/>
            <field name="help">Track overdue and upcoming payments for collections</field>
        </record>

        <!-- ================================================================ -->
        <!-- GL POSTING VERIFICATION REPORT -->
        <!-- ================================================================ -->

        <!-- GL Verification Report Tree View -->
        <record id="gl_posting_verification_report_tree" model="ir.ui.view">
            <field name="name">gl.posting.verification.report.tree</field>
            <field name="model">gl.posting.verification.report</field>
            <field name="arch" type="xml">
                <list string="GL Posting Verification Report" create="false" edit="false" delete="false"
                      decoration-danger="posting_status == 'unbalanced'"
                      decoration-success="posting_status == 'balanced'">
                    <field name="payment_ref"/>
                    <field name="payment_type"/>
                    <field name="posting_date"/>
                    <field name="gl_account"/>
                    <field name="account_name"/>
                    <field name="debit"/>
                    <field name="credit"/>
                    <field name="posting_status"/>
                    <field name="variance"/>
                </list>
            </field>
        </record>

        <!-- GL Verification Report Form View -->
        <record id="gl_posting_verification_report_form" model="ir.ui.view">
            <field name="name">gl.posting.verification.report.form</field>
            <field name="model">gl.posting.verification.report</field>
            <field name="arch" type="xml">
                <form string="GL Posting Verification Report" create="false" edit="false" delete="false">
                    <sheet>
                        <div class="alert alert-success" role="alert" invisible="posting_status != 'balanced'">
                            âœ… GL Posting is <strong>BALANCED</strong>
                        </div>
                        <div class="alert alert-danger" role="alert" invisible="posting_status != 'unbalanced'">
                            âŒ GL Posting is <strong>UNBALANCED</strong> - Variance: <field name="variance" readonly="1"/>
                        </div>

                        <group>
                            <group>
                                <field name="payment_ref" readonly="1"/>
                                <field name="payment_type" readonly="1"/>
                            </group>
                            <group>
                                <field name="posting_date" readonly="1"/>
                                <field name="posting_status" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <group>
                                <field name="gl_account" readonly="1"/>
                                <field name="account_name" readonly="1"/>
                            </group>
                            <group>
                                <field name="debit" readonly="1"/>
                                <field name="credit" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <field name="payment_amount" readonly="1"/>
                            <field name="variance" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- GL Verification Report Action -->
        <record id="action_gl_posting_verification_report" model="ir.actions.act_window">
            <field name="name">GL Posting Verification Report</field>
            <field name="res_model">gl.posting.verification.report</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="gl_posting_verification_report_tree"/>
            <field name="help">Verify all GL entries are balanced and correctly posted</field>
        </record>

        <!-- ================================================================ -->
        <!-- MENU ITEMS FOR NOTIFICATIONS & REPORTS -->
        <!-- ================================================================ -->

        <!-- Reports Submenu -->
        <menuitem id="menu_payment_reports"
                 name="Reports &amp; Analytics"
                 parent="menu_payments_documents"
                 sequence="50"/>

        <menuitem id="menu_payment_dashboard"
                 name="ðŸ“Š Payment Dashboard"
                 parent="menu_payments_documents"
                 sequence="1"
                 action="action_payment_dashboard"/>

        <menuitem id="menu_payment_reconciliation_report"
                 name="Reconciliation Report"
                 parent="menu_payment_reports"
                 sequence="10"
                 action="action_payment_reconciliation_report"/>

        <menuitem id="menu_payment_aging_report"
                 name="Aging Report (Collections)"
                 parent="menu_payment_reports"
                 sequence="11"
                 action="action_payment_aging_report"/>

        <menuitem id="menu_gl_posting_verification"
                 name="GL Posting Verification"
                 parent="menu_payment_reports"
                 sequence="12"
                 action="action_gl_posting_verification_report"/>

        <!-- Notification Settings Submenu -->
        <menuitem id="menu_payment_notifications"
                 name="âš™ï¸ Notification Settings"
                 parent="menu_payments_documents"
                 sequence="40"/>

        <menuitem id="menu_notification_templates"
                 name="Email Templates"
                 parent="menu_payment_notifications"
                 sequence="10"
                 action="action_payment_notification_template"
                 groups="base.group_system"/>

        <menuitem id="menu_notification_logs"
                 name="Notification Logs"
                 parent="menu_payment_notifications"
                 sequence="11"
                 action="action_payment_notification_log"/>

    </data>
</odoo>


